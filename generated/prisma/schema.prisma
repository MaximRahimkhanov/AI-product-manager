generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  quantity    Int
  image       String?
  category    String?
  description String?
  createdAt   DateTime @default(now())
}
